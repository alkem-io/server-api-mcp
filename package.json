{
  "name": "alkemio-mcp-server",
  "version": "0.6.0",
  "description": "Alkemio MCP Server - exposes Alkemio GraphQL API as MCP tools",
  "type": "module",
  "bin": {
    "alkemio-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "schema.graphql"
  ],
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && mcp-build",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@alkemio/client-lib": "^0.35.0",
    "dotenv": "^16.5.0",
    "mcp-framework": "^0.2.13",
    "graphql-request": "^6.1.0",
    "graphql": "^16.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.19.0"
  }
}
